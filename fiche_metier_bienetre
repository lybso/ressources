window.addEventListener('scroll',()=>{const t=document.documentElement.scrollHeight-window.innerHeight;document.getElementById('prog').style.width=(window.scrollY/t*100)+'%'});
const secs=document.querySelectorAll('section[id]'),nls=document.querySelectorAll('.nav-links a');
window.addEventListener('scroll',()=>{let c='';secs.forEach(s=>{if(window.scrollY>=s.offsetTop-80)c=s.id});nls.forEach(a=>a.classList.toggle('active',a.getAttribute('href')==='#'+c))});
function selProfil(p){document.getElementById('pA').classList.toggle('sel',p==='A');document.getElementById('pB').classList.toggle('sel',p==='B')}
let aS={};
const N={'hormones+active':{t:'Équilibre hormonal pour femmes actives',d:'Tu accompagnes des femmes de 25-45 ans qui subissent les effets du déséquilibre hormonal — fatigue, irritabilité, cycle irrégulier — sans que personne ne les ait aidées à comprendre pourquoi.',c:'Femmes actives 25-45 ans · SPM · SOPK · Périménopause',tr:'"En 12 semaines, retrouver un cycle régulier, une énergie stable et une relation sereine à ton corps."'},'hormones+perimenopause':{t:'Accompagnement périménopause & transition',d:'Tu aides des femmes de 40-55 ans à traverser cette transition avec clarté et sérénité — en comprenant ce qui se passe dans leur corps et en ajustant naturellement.',c:'Femmes 40-55 ans en périménopause ou ménopause',tr:'"Vivre cette transition non pas comme une perte, mais comme une nouvelle façon d\'habiter ton corps."'},'stress+active':{t:'Gestion du stress & récupération pour femmes surmenées',d:'Tu t\'adresses aux femmes qui ont tout — la carrière, la famille, les projets — mais qui ne récupèrent plus vraiment.',c:'Entrepreneures · Managers · Femmes multi-casquettes épuisées',tr:'"En 10 semaines, passer d\'un état de survie permanent à un équilibre qui tient vraiment."'},'stress+maman':{t:'Équilibre émotionnel pour jeunes mamans',d:'Tu accompagnes les femmes dans la période post-partum élargie — où le corps, les émotions et l\'identité sont encore en reconstruction.',c:'Jeunes mamans · Post-partum · Retour au travail',tr:'"Retrouver ton équilibre intérieur après la naissance — sans culpabilité, sans pression."'},'digestion+jeune':{t:'Relation apaisée à l\'alimentation & digestion',d:'Tu travailles avec des femmes qui ont une relation complexe à la nourriture ou des troubles digestifs chroniques qui empoisonnent leur quotidien.',c:'Femmes 25-40 ans · Troubles digestifs · Alimentation émotionnelle',tr:'"Comprendre ton corps, apaiser ta digestion et retrouver une relation sereine à ce que tu manges."'},'mental+active':{t:'Clarté mentale & gestion des émotions',d:'Tu accompagnes des femmes qui ont de grands projets mais dont la tête les empêche d\'avancer — anxiété, perfectionnisme, procrastination.',c:'Entrepreneures · Femmes ambitieuses bloquées',tr:'"Sortir du mental qui sabote et construire une clarté qui tient."'},'sommeil+jeune':{t:'Récupération profonde & énergie durable',d:'Tu travailles avec des femmes épuisées qui dorment mais ne récupèrent pas — dont le système nerveux est en mode survie permanente.',c:'Femmes 30-45 ans · Insomnie · Fatigue chronique',tr:'"Retrouver un sommeil profond et une énergie qui dure — naturellement."'},'perinatalite+maman':{t:'Accompagnement périnatal & préparation naturelle',d:'Tu prépares les femmes à la naissance et les accompagnes dans le post-partum avec une approche naturelle et holistique.',c:'Femmes enceintes · Jeunes mamans · Post-partum',tr:'"Vivre ta grossesse avec confiance, ton post-partum avec douceur."'}};
function aStep(q,v){aS['q'+q]=v;document.querySelectorAll('#q'+q+' .arbre-opt').forEach(o=>o.classList.remove('sel'));event.target.classList.add('sel');setTimeout(()=>{const nq=document.getElementById('q'+(q+1));if(nq){nq.classList.add('vis');nq.scrollIntoView({behavior:'smooth',block:'center'});}else{const k=(aS.q1||'')+'+'+(aS.q2||'');const n=N[k]||{t:'Bien-être global & équilibre naturel',d:'Une approche holistique pour des femmes qui cherchent à retrouver un équilibre naturel.',c:'Femmes en quête d\'équilibre naturel',tr:'"Retrouver une vie alignée avec ce que ton corps et ton esprit ont vraiment besoin."'};document.getElementById('nicheT').textContent=n.t;document.getElementById('nicheD').textContent=n.d;document.getElementById('nicheC').textContent=n.c;document.getElementById('nicheTr').textContent=n.tr;const r=document.getElementById('nicheRes');r.classList.add('vis');r.scrollIntoView({behavior:'smooth',block:'center'});}},200);}
function swOffre(p){document.querySelectorAll('.offre-panel').forEach(e=>e.classList.remove('act'));document.querySelectorAll('.offre-tab').forEach(e=>e.classList.remove('act'));document.getElementById('offre-'+p).classList.add('act');event.target.classList.add('act');}
function togObj(btn){const b=btn.nextElementSibling,o=b.classList.contains('open');document.querySelectorAll('.obj-body').forEach(x=>x.classList.remove('open'));document.querySelectorAll('.obj-btn').forEach(x=>x.classList.remove('open'));if(!o){b.classList.add('open');btn.classList.add('open');}}
function cpHook(id,btn){const t=document.getElementById(id).textContent.replace(/"/g,'');navigator.clipboard.writeText(t).then(()=>{btn.textContent='✓ Copié !';btn.classList.add('copied');setTimeout(()=>{btn.textContent='✦ Copier ce hook';btn.classList.remove('copied');},2000);});}
function togChk(el){el.classList.toggle('done')}
document.querySelectorAll('input,textarea').forEach(el=>{const k='lybso_'+(el.id||el.placeholder?.slice(0,20)||Math.random());try{const s=localStorage.getItem(k);if(s)el.value=s;}catch(e){}el.addEventListener('input',()=>{try{localStorage.setItem(k,el.value)}catch(e){}});});
</script>
</body>
</html>
